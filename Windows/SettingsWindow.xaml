<Window x:Class="VoiceKeyboard.Windows.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="VoiceKeyboard Settings"
        Width="500" Height="540"
        WindowStartupLocation="CenterScreen"
        Background="#1E1E2E"
        Foreground="White"
        ResizeMode="NoResize"
        ShowInTaskbar="True">
    <Window.Resources>
        <!-- Text styles -->
        <Style x:Key="LabelStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#E0E0F0"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Margin" Value="0,0,0,4"/>
        </Style>
        <Style x:Key="SectionStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#9999BB"/>
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Margin" Value="0,16,0,8"/>
            <Setter Property="Text" Value=""/>
        </Style>

        <!-- ComboBoxItem: explicit dark theme with high-contrast text -->
        <Style TargetType="ComboBoxItem">
            <Setter Property="Background" Value="#2A2A3E"/>
            <Setter Property="Foreground" Value="#F0F0FF"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="FontSize" Value="12"/>
            <Style.Triggers>
                <Trigger Property="IsHighlighted" Value="True">
                    <Setter Property="Background" Value="#4A4A80"/>
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#3A3A6E"/>
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Foreground" Value="#888899"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- ComboBox: dark background, white text, styled popup -->
        <Style TargetType="ComboBox">
            <Setter Property="Background" Value="#2A2A3E"/>
            <Setter Property="Foreground" Value="#F0F0FF"/>
            <Setter Property="BorderBrush" Value="#555577"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,5"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <ToggleButton x:Name="ToggleButton"
                                          Background="{TemplateBinding Background}"
                                          BorderBrush="{TemplateBinding BorderBrush}"
                                          BorderThickness="{TemplateBinding BorderThickness}"
                                          Padding="{TemplateBinding Padding}"
                                          IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                          Focusable="False">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border Background="{TemplateBinding Background}"
                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                BorderThickness="{TemplateBinding BorderThickness}">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="24"/>
                                                </Grid.ColumnDefinitions>
                                                <ContentPresenter Grid.Column="0"
                                                                  Margin="{TemplateBinding Padding}"
                                                                  VerticalAlignment="Center"/>
                                                <Path Grid.Column="1"
                                                      Data="M 0 0 L 6 6 L 12 0"
                                                      Stroke="#9999BB" StrokeThickness="1.5"
                                                      HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Grid>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="#3A3A5E"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                                <ContentPresenter x:Name="ContentSite"
                                                  IsHitTestVisible="False"
                                                  Content="{TemplateBinding SelectionBoxItem}"
                                                  ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                                  VerticalAlignment="Center"/>
                            </ToggleButton>
                            <Popup x:Name="Popup"
                                   Placement="Bottom"
                                   IsOpen="{TemplateBinding IsDropDownOpen}"
                                   AllowsTransparency="True"
                                   Focusable="False"
                                   PopupAnimation="Slide">
                                <Border x:Name="DropDownBorder"
                                        Background="#2A2A3E"
                                        BorderBrush="#555577"
                                        BorderThickness="1"
                                        MinWidth="{TemplateBinding ActualWidth}"
                                        MaxHeight="{TemplateBinding MaxDropDownHeight}">
                                    <ScrollViewer>
                                        <ItemsPresenter KeyboardNavigation.DirectionalNavigation="Contained"/>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Button -->
        <Style TargetType="Button">
            <Setter Property="Background" Value="#3A3A5E"/>
            <Setter Property="Foreground" Value="#F0F0FF"/>
            <Setter Property="BorderBrush" Value="#555577"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="12"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#4A4A6E"/>
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Background" Value="#2A2A3E"/>
                    <Setter Property="Foreground" Value="#666677"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- CheckBox / RadioButton -->
        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="#E0E0F0"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>
        <Style TargetType="RadioButton">
            <Setter Property="Foreground" Value="#E0E0F0"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>
    </Window.Resources>

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,16">
            <TextBlock Text="&#x1F3A4;" FontSize="24" VerticalAlignment="Center" Margin="0,0,10,0"/>
            <StackPanel>
                <TextBlock Text="VoiceKeyboard" FontSize="18" FontWeight="Bold" Foreground="White"/>
                <TextBlock Text="Local AI Voice Transcription  &#x2022;  ARM64" FontSize="11" Foreground="#9999BB"/>
            </StackPanel>
        </StackPanel>

        <!-- Content -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <!-- HOTKEY -->
                <TextBlock Style="{StaticResource SectionStyle}" Text="HOTKEY"/>

                <TextBlock Style="{StaticResource LabelStyle}" Text="Mode"/>
                <StackPanel Margin="0,0,0,12">
                    <RadioButton x:Name="RadioToggle" Content="Toggle  (press once to start, press again to stop)"
                                 GroupName="Mode" Margin="0,0,0,6"/>
                    <RadioButton x:Name="RadioPTT" Content="Push to Talk  (hold to record)"
                                 GroupName="Mode"/>
                </StackPanel>

                <TextBlock Style="{StaticResource LabelStyle}" Text="Hotkey Combination"/>
                <Grid Margin="0,0,0,4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Border Grid.Column="0" Background="#2A2A3E" BorderBrush="#555577" BorderThickness="1"
                            Padding="10,7" Margin="0,0,8,0">
                        <TextBlock x:Name="HotkeyDisplay" Text="Ctrl + Shift + Space"
                                   Foreground="White" FontFamily="Consolas" FontSize="13"/>
                    </Border>
                    <Button Grid.Column="1" x:Name="BtnChangeHotkey" Content="Change..." Click="BtnChangeHotkey_Click"/>
                </Grid>
                <TextBlock x:Name="PttNote"
                           Text="In Push to Talk mode, hold Ctrl+Shift to record. Release to transcribe."
                           Foreground="#9999BB" FontSize="11" Margin="0,2,0,0" Visibility="Collapsed"/>

                <!-- MODEL -->
                <TextBlock Style="{StaticResource SectionStyle}" Text="WHISPER MODEL"/>

                <TextBlock Style="{StaticResource LabelStyle}" Text="Model Size"/>
                <Grid Margin="0,0,0,4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <ComboBox x:Name="ModelCombo" Grid.Column="0" Margin="0,0,8,0">
                        <ComboBoxItem Content="Tiny  (~75 MB) — Fastest" Tag="tiny"/>
                        <ComboBoxItem Content="Base  (~142 MB) — Recommended" Tag="base" IsSelected="True"/>
                        <ComboBoxItem Content="Small  (~466 MB) — More accurate" Tag="small"/>
                        <ComboBoxItem Content="Medium  (~1.5 GB) — Most accurate" Tag="medium"/>
                    </ComboBox>
                    <Button Grid.Column="1" x:Name="BtnDownload" Content="Download" Click="BtnDownload_Click"/>
                </Grid>
                <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                    <Ellipse x:Name="ModelStatusDot" Width="8" Height="8" VerticalAlignment="Center" Margin="0,0,6,0" Fill="#FF4444"/>
                    <TextBlock x:Name="ModelStatusText" Text="Not downloaded" Foreground="#9999BB" FontSize="11"/>
                </StackPanel>
                <ProgressBar x:Name="DownloadProgress" Height="4" Margin="0,6,0,0" Visibility="Collapsed"
                             Background="#2A2A3E" Foreground="#6868FF"/>

                <!-- LANGUAGE -->
                <TextBlock Style="{StaticResource SectionStyle}" Text="LANGUAGE"/>

                <TextBlock Style="{StaticResource LabelStyle}" Text="Transcription Language"/>
                <ComboBox x:Name="LangCombo" Margin="0,0,0,4">
                    <ComboBoxItem Content="Auto-detect" Tag="auto" IsSelected="True"/>
                    <ComboBoxItem Content="English" Tag="en"/>
                    <ComboBoxItem Content="Spanish" Tag="es"/>
                    <ComboBoxItem Content="French" Tag="fr"/>
                    <ComboBoxItem Content="German" Tag="de"/>
                    <ComboBoxItem Content="Japanese" Tag="ja"/>
                    <ComboBoxItem Content="Chinese" Tag="zh"/>
                    <ComboBoxItem Content="Korean" Tag="ko"/>
                    <ComboBoxItem Content="Portuguese" Tag="pt"/>
                    <ComboBoxItem Content="Italian" Tag="it"/>
                    <ComboBoxItem Content="Russian" Tag="ru"/>
                </ComboBox>

                <!-- MICROPHONE -->
                <TextBlock Style="{StaticResource SectionStyle}" Text="MICROPHONE"/>

                <TextBlock Style="{StaticResource LabelStyle}" Text="Input Device"/>
                <Grid Margin="0,0,0,4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <ComboBox x:Name="MicCombo" Grid.Column="0" Margin="0,0,8,0"/>
                    <Button Grid.Column="1" Content="Refresh" Width="70" Click="BtnRefreshMic_Click"/>
                </Grid>

                <!-- BEHAVIOR -->
                <TextBlock Style="{StaticResource SectionStyle}" Text="BEHAVIOR"/>

                <CheckBox x:Name="ChkPasteToCurrentCursor" Margin="0,0,0,8">
                    <CheckBox.Content>
                        <StackPanel>
                            <TextBlock Text="Paste to cursor position when done" Foreground="#F0F0FF" FontSize="12"/>
                            <TextBlock Text="Transcribed text is pasted to whichever text box your cursor is in at the end of the recording. Text stays in clipboard for re-pasting with Ctrl+V."
                                       Foreground="#9999BB" FontSize="10" TextWrapping="Wrap" Margin="0,2,0,0"/>
                        </StackPanel>
                    </CheckBox.Content>
                </CheckBox>
                <CheckBox x:Name="ChkOverlay" Content="Show recording overlay" IsChecked="True" Margin="0,0,0,8"/>
                <CheckBox x:Name="ChkStartup" Content="Start with Windows" Margin="0,0,0,8"/>
            </StackPanel>
        </ScrollViewer>

        <!-- Footer -->
        <Grid Grid.Row="2" Margin="0,16,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="8"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" x:Name="StatusBar" Text="" Foreground="#9999BB" FontSize="11" VerticalAlignment="Center"/>
            <Button Grid.Column="1" Content="Cancel" Click="BtnCancel_Click" Padding="16,8"/>
            <Button Grid.Column="3" Content="Save" Click="BtnSave_Click" Padding="16,8"
                    Background="#5050AA" BorderBrush="#7070CC"/>
        </Grid>
    </Grid>
</Window>

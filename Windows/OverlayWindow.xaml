<Window x:Class="VoiceKeyboard.Windows.OverlayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="VoiceKeyboard Overlay"
        Width="220" Height="56"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        ShowActivated="False"
        Topmost="True"
        ResizeMode="NoResize"
        IsHitTestVisible="False">
    <Border Background="#DD1E1E2E"
            CornerRadius="12"
            BorderBrush="#555577"
            BorderThickness="1"
            Padding="12,8">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <!-- Status dot / spinner area -->
            <Ellipse x:Name="StatusDot"
                     Grid.Column="0"
                     Width="10" Height="10"
                     Fill="#FF4444"
                     VerticalAlignment="Center"
                     Margin="0,0,8,0">
                <Ellipse.Triggers>
                    <EventTrigger RoutedEvent="Loaded">
                        <BeginStoryboard>
                            <Storyboard RepeatBehavior="Forever">
                                <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                 From="1" To="0.3" Duration="0:0:0.6"
                                                 AutoReverse="True"/>
                            </Storyboard>
                        </BeginStoryboard>
                    </EventTrigger>
                </Ellipse.Triggers>
            </Ellipse>
            <!-- Status text -->
            <TextBlock x:Name="StatusText"
                       Grid.Column="1"
                       Text="Recording..."
                       Foreground="White"
                       FontFamily="Segoe UI"
                       FontSize="13"
                       FontWeight="SemiBold"
                       VerticalAlignment="Center"/>
        </Grid>
    </Border>
</Window>
